@model IEnumerable<DataApi.Models.Customer>

<h2>Справочник клиентов</h2>

<!-- Форма быстрого добавления -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <!-- Кнопка, которая открывает форму -->
    <button class="btn btn-success" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreateForm">
        + Добавить клиента
    </button>
</div>

<!-- Скрытый блок с формой -->
<div class="collapse mb-4" id="collapseCreateForm">
    <div class="card card-body shadow-sm">
        <h5 class="card-title">Данные нового клиента</h5>
        <form asp-action="CreateCustomer" method="post" class="row g-3">
            <div class="col-md-3">
                <input name="FirstName" class="form-control" placeholder="Имя" required />
            </div>
            <div class="col-md-3">
                <input name="LastName" class="form-control" placeholder="Фамилия" required />
            </div>
            <div class="col-md-4">
                <input name="Address" class="form-control" placeholder="Адрес" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<!-- Таблица клиентов -->
<div class="custom-table-wrapper">
    <!-- Блок 1: Только шапка -->
    <div class="table-header-only">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ФИО</th>
                    <th>Адрес</th>
                </tr>
            </thead>
        </table>
    </div>

    <!-- Блок 2: Только данные с прокруткой -->
    <div class="table-body-scroll">
        <table class="table table-hover mb-0">
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.FirstName @c.LastName</td>
                        <td>@c.Address</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-action="Orders" class="btn btn-link">Вернуться к заказам</a>