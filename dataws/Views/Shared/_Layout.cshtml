<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Управление заказами</title>
    <!-- Подключаем стили Bootstrap напрямую из сети -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
          crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site-tables.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Система заказов</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Orders" asp-action="Orders">Заказы</a>
                <a class="nav-link" asp-controller="Customers" asp-action="Customers">Клиенты</a>
                <a class="nav-link" asp-controller="Profile" asp-action="Index">Личный кабинет</a>
            </div>
        </div>
        <div class="navbar-nav ms-auto">
            @if (User.Identity.IsAuthenticated)
            {
                <span class="navbar-text me-3">
                    @User.Identity.Name
                </span>

                <form asp-controller="Account"
                    asp-action="Logout"
                    method="post">

                    <button type="submit"
                            class="btn btn-outline-light btn-sm">
                        Выход
                    </button>
                </form>
            }
            else
            {
                <a class="nav-link"
                asp-controller="Account"
                asp-action="Login">
                    Вход
                </a>

                <a class="nav-link"
                asp-controller="Account"
                asp-action="Register">
                    Регистрация
                </a>
            }
        </div>        
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <!-- Подключаем скрипты для работы кнопок -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
