@model dynamic

@{
    ViewData["Title"] = "Список заказов";
}

<h2>Заказы курьера</h2>

<button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addOrderModal">
    Добавить заказ
</button>
<div class="modal fade" id="addOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Новый заказ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateOrder" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Клиент</label>
                        <!-- Используем ViewBag.Customers, который наполним в контроллере -->
                        <select name="CustomerId" class="form-select" required asp-items="ViewBag.Customers">
                            <option value="">-- Выберите клиента --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Дата и время выполнения</label>
                        <input type="datetime-local" name="OrderDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Сумма</label>
                        <input type="number" step="0.01" name="Amount" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Статус</label>
                        <select name="Status" class="form-select">
                            <option value="0">Ожидание</option>
                            <option value="1">Доставлен</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-success">Сохранить заказ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="custom-table-wrapper">
    <!-- Блок 1: Только шапка -->
    <div class="table-header-only">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Клиент</th>
                    <th>Адрес</th>
                    <th>Статус</th>
                </tr>
            </thead>
        </table>
    </div>

    <!-- Блок 2: Только данные с прокруткой -->
    <div class="table-body-scroll">
        <table class="table table-hover mb-0">
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.Amount.ToString("C")</td>
                        <td>@item.CustomerName</td>
                        <td>@item.Address</td>
                        <td>
                            <button class="btn btn-sm btn-primary" 
                                    onclick="updateStatus(@item.Id, @(item.Status == 1 ? 0 : 1))">
                                @* @if(item.Id==1) 
                                {
                                    @:Доставлен
                                } else 
                                {
                                    @:Ожидание
                                } *@
                                @(item.Status == 1? "Доставлен" : "Ожидание")                        
                            </button>
                        </td>                
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    async function updateStatus(orderId, newStatus) {
        if (!confirm('Вы уверены, что хотите изменить статус?')) return;

        try {
            // Вызываем ваш метод UpdateStatus
            const response = await fetch(`/api/Data/UpdateStatus/${orderId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(newStatus) // Отправляем short newStatus
            });

            if (response.ok) {
                alert('Статус обновлен!');
                location.reload(); // Перезагружаем страницу, чтобы увидеть изменения
            } else {
                const error = await response.text();
                alert('Ошибка: ' + error);
            }
        } catch (err) {
            console.error('Ошибка запроса:', err);
            alert('Не удалось связаться с сервером');
        }
    }
</script>
}
